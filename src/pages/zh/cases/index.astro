---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getLangFromUrl, t, localizedPath } from '../../../utils/i18n';
import { getLocalizedCollection } from '../../../utils/content';

const lang = getLangFromUrl(Astro.url);
const i18n = t(lang);
const allCases = await getLocalizedCollection('cases', lang);
const sortedCases = allCases.sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title={i18n.cases.title} description={i18n.cases.subtitle} lang={lang}>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-4xl font-bold text-charcoal">{i18n.cases.title}</h1>
    <p class="mt-3 text-muted">{i18n.cases.subtitle}</p>
    {sortedCases.length > 0 ? (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 mt-10">
        {sortedCases.map((c) => {
          const cs = c.id.replace(`${lang}/`, '');
          return (
            <a href={localizedPath(lang, `cases/${cs}`)} class="group block bg-white rounded-lg overflow-hidden shadow-sm hover:shadow-md transition-all duration-300 p-6">
              <span class="text-xs font-medium text-gold uppercase tracking-wider">{c.data.category}</span>
              <h3 class="mt-2 font-medium text-lg text-charcoal group-hover:text-rose transition-colors">{c.data.title}</h3>
              <p class="mt-2 text-sm text-muted line-clamp-2">{c.data.challenge}</p>
              <div class="mt-4 flex items-center justify-between text-xs text-muted"><span>{c.data.clientName}</span><span>{c.data.clientRegion}</span></div>
            </a>
          );
        })}
      </div>
    ) : (
      <div class="text-center py-20 text-muted">暂无案例</div>
    )}
  </section>
</BaseLayout>
