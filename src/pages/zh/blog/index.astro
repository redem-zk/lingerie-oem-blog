---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import BlogCard from '../../../components/BlogCard.astro';
import { getLangFromUrl, t, localizedPath } from '../../../utils/i18n';
import { getLocalizedCollection } from '../../../utils/content';

const lang = getLangFromUrl(Astro.url);
const i18n = t(lang);

const allPosts = await getLocalizedCollection('blog', lang);
const sortedPosts = allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
const selectedTag = Astro.url.searchParams.get('tag');
const filteredPosts = selectedTag
  ? sortedPosts.filter((p) => p.data.tags.includes(selectedTag))
  : sortedPosts;
const allTags = [...new Set(sortedPosts.flatMap((p) => p.data.tags))];
---

<BaseLayout title={i18n.blog.title} description={i18n.blog.subtitle} lang={lang}>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-16">
    <h1 class="text-4xl font-bold text-charcoal">{i18n.blog.title}</h1>
    <p class="mt-3 text-muted">{i18n.blog.subtitle}</p>
    {allTags.length > 0 && (
      <div class="flex flex-wrap gap-2 mt-8">
        <a href={localizedPath(lang, 'blog')} class={`px-4 py-1.5 rounded-full text-sm font-medium transition-colors ${!selectedTag ? 'bg-gold text-white' : 'bg-white text-charcoal hover:bg-rose-light/20 border border-rose-light/30'}`}>All</a>
        {allTags.map((tag) => (
          <a href={`${localizedPath(lang, 'blog')}?tag=${tag}`} class={`px-4 py-1.5 rounded-full text-sm font-medium transition-colors ${selectedTag === tag ? 'bg-gold text-white' : 'bg-white text-charcoal hover:bg-rose-light/20 border border-rose-light/30'}`}>{tag}</a>
        ))}
      </div>
    )}
    {filteredPosts.length > 0 ? (
      <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-8 mt-10">{filteredPosts.map((p) => <BlogCard post={p} />)}</div>
    ) : (
      <div class="text-center py-20 text-muted">暂无文章</div>
    )}
  </section>
</BaseLayout>
