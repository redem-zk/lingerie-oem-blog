---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ContactForm from '../../components/ContactForm.astro';
import { getLangFromUrl, t } from '../../utils/i18n';

const lang = getLangFromUrl(Astro.url);
const i18n = t(lang);
---

<BaseLayout title={i18n.contact.title} lang={lang}>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <span class="section-tag">{i18n.nav.contact}</span>
    <h1 class="text-4xl sm:text-5xl font-bold text-charcoal mt-3 leading-tight">{i18n.contact.title}</h1>

    <div class="grid md:grid-cols-2 gap-16 mt-12">
      <div class="space-y-8">
        <div class="flex gap-4">
          <div class="w-10 h-10 rounded-xl bg-rose-light/20 flex items-center justify-center shrink-0">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-rose)" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
          </div>
          <div>
            <h3 class="font-medium text-charcoal text-sm">{i18n.contact.address}</h3>
            <p class="text-sm text-muted mt-1">123 Factory Rd, Industrial Zone<br/>[Your City], China</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="w-10 h-10 rounded-xl bg-rose-light/20 flex items-center justify-center shrink-0">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-rose)" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </div>
          <div>
            <h3 class="font-medium text-charcoal text-sm">{i18n.contact.phone}</h3>
            <p class="text-sm text-muted mt-1">+86-xxx-xxxx-xxxx</p>
          </div>
        </div>
        <div class="flex gap-4">
          <div class="w-10 h-10 rounded-xl bg-rose-light/20 flex items-center justify-center shrink-0">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="var(--color-rose)" stroke-width="2"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
          </div>
          <div>
            <h3 class="font-medium text-charcoal text-sm">{i18n.contact.email}</h3>
            <p class="text-sm text-muted mt-1">info@lingerie-oem.com</p>
          </div>
        </div>
      </div>

      <div class="card p-8">
        <h2 class="text-xl font-bold text-charcoal mb-6">{i18n.contact.formTitle}</h2>
        <ContactForm />
      </div>
    </div>
  </section>
</BaseLayout>
