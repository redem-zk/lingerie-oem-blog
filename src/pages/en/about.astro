---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getLangFromUrl, t } from '../../utils/i18n';
import { getLocalizedCollection } from '../../utils/content';

const lang = getLangFromUrl(Astro.url);
const i18n = t(lang);

const pages = await getLocalizedCollection('pages', lang);
const aboutPage = pages.find((p) => p.id === `${lang}/about`);
---

<BaseLayout title={i18n.about.title} lang={lang}>
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="max-w-3xl">
      <span class="section-tag">{i18n.nav.about}</span>
      <h1 class="text-4xl sm:text-5xl font-bold text-charcoal mt-3 leading-tight">{i18n.about.title}</h1>
      <p class="mt-6 text-lg text-muted leading-relaxed">{i18n.about.intro}</p>
      {aboutPage?.body && <div class="mt-8 prose" set:html={aboutPage.body} />}
    </div>

    <div class="grid grid-cols-2 md:grid-cols-3 gap-5 mt-16">
      {['factory-1.jpg', 'factory-2.jpg', 'factory-3.jpg'].map((img) => (
        <div class="aspect-[4/3] rounded-xl overflow-hidden bg-cream-dark flex items-center justify-center">
          <div class="text-center text-muted-light">
            <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.4" class="mx-auto mb-2"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
            <span class="text-xs">{img}</span>
          </div>
        </div>
      ))}
    </div>

    <div class="grid md:grid-cols-3 gap-6 mt-16">
      <div class="card p-8">
        <div class="w-10 h-10 rounded-xl bg-rose-light/20 flex items-center justify-center mb-4">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-rose)" stroke-width="1.5"><rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </div>
        <h3 class="font-bold text-lg mb-2">{i18n.about.lines}</h3>
        <p class="text-sm text-muted leading-relaxed">12 production lines covering bras, panties, and shapewear.</p>
      </div>
      <div class="card p-8">
        <div class="w-10 h-10 rounded-xl bg-rose-light/20 flex items-center justify-center mb-4">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-rose)" stroke-width="1.5"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
        </div>
        <h3 class="font-bold text-lg mb-2">{i18n.about.quality}</h3>
        <p class="text-sm text-muted leading-relaxed">Four-stage QC: incoming inspection, inline check, final inspection, shipment audit.</p>
      </div>
      <div class="card p-8">
        <div class="w-10 h-10 rounded-xl bg-rose-light/20 flex items-center justify-center mb-4">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--color-rose)" stroke-width="1.5"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
        </div>
        <h3 class="font-bold text-lg mb-2">{i18n.about.partners}</h3>
        <p class="text-sm text-muted leading-relaxed">Served 50+ brands globally, exporting to EU, US, Japan, Korea, and SE Asia.</p>
      </div>
    </div>
  </section>
</BaseLayout>
