---
import { getLangFromUrl, t, localizedPath } from '../utils/i18n';
import type { CollectionEntry } from 'astro:content';

interface Props {
  post: CollectionEntry<'blog'>;
}

const lang = getLangFromUrl(Astro.url);
const i18n = t(lang);
const { post } = Astro.props;
const slug = post.id.replace(`${lang}/`, '');
---

<article class="group">
  <a href={localizedPath(lang, `blog/${slug}`)} class="block overflow-hidden rounded-xl aspect-[16/10] mb-5">
    {post.data.coverImage ? (
      <img
        src={post.data.coverImage}
        alt={post.data.title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full bg-cream-dark rounded-xl flex items-center justify-center text-muted-light">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.4"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
      </div>
    )}
  </a>
  <div class="flex flex-wrap gap-2 mb-3">
    {post.data.tags.slice(0, 2).map((tag) => (
      <span class="text-[10px] font-medium text-gold uppercase tracking-wider bg-gold/5 px-2.5 py-1 rounded-full">{tag}</span>
    ))}
  </div>
  <a href={localizedPath(lang, `blog/${slug}`)}>
    <h3 class="font-semibold text-lg text-charcoal group-hover:text-rose transition-colors leading-snug">
      {post.data.title}
    </h3>
  </a>
  <p class="mt-2 text-sm text-muted leading-relaxed line-clamp-2">{post.data.excerpt}</p>
  <time datetime={post.data.date.toISOString()} class="mt-4 block text-xs text-muted-light">
    {post.data.date.toLocaleDateString(lang === 'zh' ? 'zh-CN' : 'en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })}
  </time>
</article>
