---
import { getLangFromUrl, t, localizedPath } from '../utils/i18n';

const lang = getLangFromUrl(Astro.url);
const i18n = t(lang);
---

<section class="relative overflow-hidden bg-gradient-to-br from-cream via-[#faf5f2] to-rose-light/25">
  <!-- Decorative blobs -->
  <div class="absolute top-0 right-0 w-[600px] h-[600px] bg-rose-light/15 rounded-full blur-3xl -translate-y-1/2 translate-x-1/3"></div>
  <div class="absolute bottom-0 left-0 w-[400px] h-[400px] bg-gold/5 rounded-full blur-3xl translate-y-1/3 -translate-x-1/4"></div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-24 sm:py-32 lg:py-40">
    <div class="grid lg:grid-cols-2 gap-16 items-center">
      <!-- Text -->
      <div class="space-y-8 animate-fade-up">
        <div class="flex items-center gap-3">
          <span class="w-8 h-px bg-gold/50"></span>
          <span class="text-xs font-medium tracking-[0.25em] uppercase text-gold">
            {lang === 'zh' ? '内衣代工专家' : 'Lingerie Manufacturing Expert'}
          </span>
        </div>
        <h1 class="text-4xl sm:text-5xl lg:text-6xl xl:text-7xl font-bold text-charcoal leading-[1.08]">
          {lang === 'zh'
            ? '为全球品牌打造\n精致内衣'
            : 'Crafting Exquisite\nIntimate Apparel'}
        </h1>
        <p class="text-lg text-muted max-w-md leading-relaxed font-light">
          {lang === 'zh'
            ? '15 年专注女性内衣代工，从设计打样到量产交付，一站式服务全球品牌。'
            : 'From concept to bulk production — we craft intimate apparel for brands worldwide with 15+ years of expertise.'}
        </p>
        <div class="flex flex-wrap gap-4 pt-4">
          <a href={localizedPath(lang, 'inquiry')} class="btn-primary">
            {i18n.home.ctaInquiry}
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="5" y1="12" x2="19" y2="12"/><polyline points="12 5 19 12 12 19"/></svg>
          </a>
          <a href={localizedPath(lang, 'products')} class="btn-outline">
            {i18n.home.ctaProducts}
          </a>
        </div>
        <!-- Trust badges -->
        <div class="flex items-center gap-8 pt-4 text-xs text-muted-light">
          <div class="flex items-center gap-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            ISO 9001
          </div>
          <div class="flex items-center gap-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            OEKO-TEX
          </div>
          <div class="flex items-center gap-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>
            {lang === 'zh' ? '50+ 品牌合作' : '50+ Brands'}
          </div>
        </div>
      </div>

      <!-- Visual -->
      <div class="hidden lg:block relative">
        <div class="relative aspect-[4/5] rounded-2xl overflow-hidden shadow-2xl">
          <div class="absolute inset-0 bg-gradient-to-br from-rose-light/40 via-cream-dark/20 to-transparent z-10"></div>
          <div class="w-full h-full bg-[#ede4df] flex items-center justify-center">
            <div class="text-center z-0">
              <svg width="80" height="80" viewBox="0 0 24 24" fill="none" stroke="var(--color-muted-light)" stroke-width="0.8" class="mx-auto mb-3 opacity-60">
                <path d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/>
              </svg>
              <span class="text-sm text-muted-light tracking-wider uppercase">Product Showcase</span>
            </div>
          </div>
        </div>
        <!-- Floating badge -->
        <div class="absolute -bottom-4 -left-4 bg-white rounded-xl shadow-xl px-5 py-3 flex items-center gap-3">
          <div class="w-8 h-8 rounded-full bg-gold/10 flex items-center justify-center">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--color-gold)" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
          </div>
          <div>
            <div class="text-xs font-semibold text-charcoal">{lang === 'zh' ? '已认证工厂' : 'Certified Factory'}</div>
            <div class="text-[10px] text-muted-light">ISO 9001 & OEKO-TEX</div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
