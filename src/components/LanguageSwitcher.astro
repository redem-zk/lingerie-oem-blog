---
import { getLangFromUrl, localizedPath, t } from '../utils/i18n';

const currentLang = getLangFromUrl(Astro.url);
const otherLang = currentLang === 'en' ? 'zh' : 'en';
const i18n = t(currentLang);

// Build the corresponding URL in the other language
const currentPath = Astro.url.pathname;
const pathWithoutLang = currentPath.replace(/^\/(en|zh)/, '') || '/';
const otherUrl = `/${otherLang}${pathWithoutLang}`;
---

<a
  href={otherUrl}
  class="inline-flex items-center gap-1.5 text-sm font-medium text-muted hover:text-gold transition-colors"
  hreflang={otherLang}
>
  <span class="hidden sm:inline">{i18n.language[otherLang]}</span>
  <span class="sm:hidden">{otherLang.toUpperCase()}</span>
  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <circle cx="12" cy="12" r="10"/>
    <path d="M2 12h20M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
  </svg>
</a>
