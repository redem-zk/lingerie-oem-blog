---
import { getLangFromUrl, t, localizedPath } from '../utils/i18n';

const lang = getLangFromUrl(Astro.url);
const i18n = t(lang);
---

<footer class="bg-charcoal text-cream mt-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20">
    <div class="grid grid-cols-1 md:grid-cols-12 gap-12">
      <!-- Brand -->
      <div class="md:col-span-5">
        <span class="font-serif-en text-2xl font-bold tracking-wide">
          Lingerie<span class="text-rose">OEM</span>
        </span>
        <p class="mt-4 text-sm text-cream-dark/60 max-w-sm leading-relaxed">
          {lang === 'zh'
            ? '专注女性内衣代工 15 年。从设计到交付，为全球品牌提供一站式制造服务。'
            : '15 years of expertise in lingerie manufacturing. End-to-end service for brands worldwide — from design to delivery.'}
        </p>
        <div class="flex gap-4 mt-6">
          <a href="#" class="w-9 h-9 rounded-full border border-cream-dark/20 flex items-center justify-center text-cream-dark/50 hover:text-gold hover:border-gold/40 transition-all" aria-label="LinkedIn">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          </a>
          <a href="#" class="w-9 h-9 rounded-full border border-cream-dark/20 flex items-center justify-center text-cream-dark/50 hover:text-gold hover:border-gold/40 transition-all" aria-label="Instagram">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 1 0 0 12.324 6.162 6.162 0 0 0 0-12.324zM12 16a4 4 0 1 1 0-8 4 4 0 0 1 0 8zm6.406-11.845a1.44 1.44 0 1 0 0 2.881 1.44 1.44 0 0 0 0-2.881z"/></svg>
          </a>
        </div>
      </div>

      <!-- Quick Links -->
      <div class="md:col-span-3">
        <h4 class="text-xs font-medium tracking-[0.2em] uppercase text-rose-light/80 mb-5">
          {lang === 'zh' ? '快速链接' : 'Quick Links'}
        </h4>
        <div class="space-y-3">
          {[
            [i18n.nav.products, 'products'],
            [i18n.nav.about, 'about'],
            [i18n.nav.cases, 'cases'],
            [i18n.nav.blog, 'blog'],
          ].map(([label, path]) => (
            <a href={localizedPath(lang, path)} class="block text-sm text-cream-dark/50 hover:text-gold transition-colors">{label}</a>
          ))}
        </div>
      </div>

      <!-- Contact -->
      <div class="md:col-span-4">
        <h4 class="text-xs font-medium tracking-[0.2em] uppercase text-rose-light/80 mb-5">
          {i18n.nav.contact}
        </h4>
        <div class="space-y-3 text-sm text-cream-dark/50">
          <p class="flex items-start gap-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mt-0.5 shrink-0 opacity-50"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            qq641032841@163.com
          </p>
          <p class="flex items-start gap-2">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class="mt-0.5 shrink-0 opacity-50"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            +86-xxx-xxxx-xxxx
          </p>
        </div>
      </div>
    </div>

    <div class="border-t border-cream-dark/10 mt-16 pt-8 flex flex-col sm:flex-row justify-between text-xs text-cream-dark/30">
      <p>&copy; {new Date().getFullYear()} Lingerie OEM. {i18n.footer.copyright}</p>
      <div class="flex gap-6 mt-2 sm:mt-0">
        <a href="#" class="hover:text-gold transition-colors">{i18n.footer.privacy}</a>
        <a href="#" class="hover:text-gold transition-colors">{i18n.footer.terms}</a>
      </div>
    </div>
  </div>
</footer>
