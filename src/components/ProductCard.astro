---
import { getLangFromUrl, t, localizedPath } from '../utils/i18n';
import type { CollectionEntry } from 'astro:content';

interface Props {
  product: CollectionEntry<'products'>;
}

const lang = getLangFromUrl(Astro.url);
const i18n = t(lang);
const { product } = Astro.props;
const slug = product.id.replace(`${lang}/`, '');
---

<a
  href={localizedPath(lang, `products/${slug}`)}
  class="card group block"
>
  <div class="aspect-[3/4] overflow-hidden relative">
    {product.data.images.length > 0 ? (
      <img
        src={product.data.images[0]}
        alt={product.data.title}
        class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-700 ease-out"
        loading="lazy"
      />
    ) : (
      <div class="w-full h-full bg-cream-dark flex items-center justify-center text-muted-light text-sm">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.4"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
      </div>
    )}
    <!-- Category badge -->
    <span class="absolute top-3 left-3 bg-white/90 backdrop-blur-sm text-gold text-[10px] font-medium uppercase tracking-wider px-2.5 py-1 rounded-full">
      {i18n.products.categories[product.data.category]}
    </span>
  </div>
  <div class="p-5">
    <h3 class="font-semibold text-charcoal group-hover:text-rose transition-colors leading-snug">
      {product.data.title}
    </h3>
    <p class="mt-2 text-xs text-muted-light">{product.data.fabric}</p>
  </div>
</a>
